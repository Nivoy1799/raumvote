{
  "uid": "raumvote-app",
  "title": "App Instances",
  "tags": ["raumvote", "app"],
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Health Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "200": { "text": "Healthy", "color": "green" } } },
            { "type": "special", "options": { "match": "null", "result": { "text": "Down", "color": "red" } } }
          ]
        }
      },
      "targets": [
        {
          "query": "from(bucket: v.defaultBucket)\n  |> range(start: -1m)\n  |> filter(fn: (r) => r._measurement == \"http_response\")\n  |> filter(fn: (r) => r._field == \"http_response_code\")\n  |> last()\n  |> yield(name: \"status\")",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Avg Response Time",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "query": "from(bucket: v.defaultBucket)\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"http_response\")\n  |> filter(fn: (r) => r._field == \"response_time\")\n  |> mean()\n  |> yield(name: \"avg\")",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Pending Jobs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "targets": [
        {
          "query": "from(bucket: v.defaultBucket)\n  |> range(start: -1m)\n  |> filter(fn: (r) => r._measurement == \"app_metrics\")\n  |> filter(fn: (r) => r._field == \"jobs_pending\")\n  |> last()\n  |> yield(name: \"pending\")",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Pending Images",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "targets": [
        {
          "query": "from(bucket: v.defaultBucket)\n  |> range(start: -1m)\n  |> filter(fn: (r) => r._measurement == \"app_metrics\")\n  |> filter(fn: (r) => r._field == \"images_pending\")\n  |> last()\n  |> yield(name: \"pending\")",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Failed Jobs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "query": "from(bucket: v.defaultBucket)\n  |> range(start: -1m)\n  |> filter(fn: (r) => r._measurement == \"app_metrics\")\n  |> filter(fn: (r) => r._field == \"jobs_failed\")\n  |> last()\n  |> yield(name: \"failed\")",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Health Response Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 20, "lineWidth": 2, "gradientMode": "scheme" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "query": "from(bucket: v.defaultBucket)\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"http_response\")\n  |> filter(fn: (r) => r._field == \"response_time\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean)\n  |> yield(name: \"latency\")",
          "refId": "A"
        }
      ]
    },
    {
      "id": 20,
      "title": "App CPU per Replica",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "fillOpacity": 15, "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      },
      "targets": [
        {
          "query": "from(bucket: v.defaultBucket)\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"docker_container_cpu\")\n  |> filter(fn: (r) => r._field == \"usage_percent\")\n  |> filter(fn: (r) => r[\"com.docker.compose.service\"] == \"app\")\n  |> keep(columns: [\"_time\", \"_value\", \"container_name\"])\n  |> aggregateWindow(every: v.windowPeriod, fn: mean)\n  |> yield(name: \"cpu\")",
          "refId": "A"
        }
      ]
    },
    {
      "id": 21,
      "title": "App Memory per Replica",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "query": "from(bucket: v.defaultBucket)\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"docker_container_mem\")\n  |> filter(fn: (r) => r._field == \"usage\")\n  |> filter(fn: (r) => r[\"com.docker.compose.service\"] == \"app\")\n  |> keep(columns: [\"_time\", \"_value\", \"container_name\"])\n  |> aggregateWindow(every: v.windowPeriod, fn: mean)\n  |> yield(name: \"mem\")",
          "refId": "A"
        }
      ]
    },
    {
      "id": 30,
      "title": "Queue Depth Over Time",
      "description": "Job queue and image pipeline depth from /api/metrics",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "jobs_pending" },
            "properties": [
              { "id": "displayName", "value": "Jobs Pending" },
              { "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "jobs_processing" },
            "properties": [
              { "id": "displayName", "value": "Jobs Processing" },
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "images_pending" },
            "properties": [
              { "id": "displayName", "value": "Images Pending" },
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "images_generating" },
            "properties": [
              { "id": "displayName", "value": "Images Generating" },
              { "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "query": "from(bucket: v.defaultBucket)\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"app_metrics\")\n  |> filter(fn: (r) => r._field == \"jobs_pending\" or r._field == \"jobs_processing\" or r._field == \"images_pending\" or r._field == \"images_generating\")\n  |> aggregateWindow(every: v.windowPeriod, fn: last)\n  |> yield(name: \"queue\")",
          "refId": "A"
        }
      ]
    },
    {
      "id": 31,
      "title": "Top Endpoints by Request Count",
      "description": "Most-requested API paths from nginx access logs",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "topk(15, sum by (request_uri) (count_over_time({service=\"nginx\"} | json [$__range])))",
          "legendFormat": "{{request_uri}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 40,
      "title": "App Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service=\"app\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    }
  ],
  "schemaVersion": 39
}
